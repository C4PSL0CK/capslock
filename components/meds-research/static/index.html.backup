<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MEDS Dashboard</title>
    <link rel="stylesheet" href="/static/css/styles.css">
</head>
<body>
    <div class="container">
        <header class="header">
            <h1>🚀 MEDS Dashboard</h1>
            <p>Multi-Environment Deployment System</p>
        </header>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value" id="total-promotions">0</div>
                <div class="stat-label">Total Promotions</div>
            </div>
            <div class="stat-card success">
                <div class="stat-value" id="approved">0</div>
                <div class="stat-label">Approved</div>
            </div>
            <div class="stat-card danger">
                <div class="stat-value" id="rejected">0</div>
                <div class="stat-label">Rejected</div>
            </div>
            <div class="stat-card warning">
                <div class="stat-value" id="avg-risk">0</div>
                <div class="stat-label">Avg Risk Score</div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Create New Promotion</h2>
            </div>
            <form id="promotion-form">
                <div class="form-row">
                    <input type="text" id="name" placeholder="Promotion Name" required>
                    <input type="text" id="app-name" placeholder="Application Name" required>
                </div>
                <div class="form-row">
                    <select id="source-env" required>
                        <option value="">Source Environment</option>
                        <option value="development">Development</option>
                        <option value="staging">Staging</option>
                    </select>
                    <select id="target-env" required>
                        <option value="">Target Environment</option>
                        <option value="staging">Staging</option>
                        <option value="production">Production</option>
                    </select>
                </div>
                <div class="form-row">
                    <input type="text" id="version" placeholder="Version (e.g., v1.2.3)" required>
                </div>
                <div class="form-group">
                    <label>Add Policies:</label>
                    <div id="policy-selector"></div>
                </div>
                <button type="submit" class="btn btn-primary">Create Promotion</button>
            </form>
        </div>

        <div class="card">
            <h2>Recent Promotions</h2>
            <div id="promotions-list"></div>
        </div>

        <div id="result-modal" class="modal">
            <div class="modal-content">
                <span class="close">&times;</span>
                <div id="result-details"></div>
            </div>
        </div>
    </div>

    <script src="/static/js/app.js"></script>
</body>
</html>
